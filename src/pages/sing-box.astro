<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Proxy Config Studio (Sing-box & Clash)</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/base64-style.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/js-yaml/4.1.0/js-yaml.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <style>
        :root {
            --bg-color: #0f172a;
            --panel-bg: rgba(30, 41, 59, 0.7);
            --border-color: rgba(255, 255, 255, 0.1);
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --accent: #3b82f6;
            --accent-hover: #2563eb;
            --danger: #ef4444;
            --success: #10b981;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
            color: var(--text-main);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        header {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 10;
        }

        header h1 {
            font-size: 1.2rem;
            font-weight: 600;
            background: linear-gradient(to right, #60a5fa, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .btn {
            background: var(--accent);
            color: white;
            border: none;
            padding: 0.5rem 1.2rem;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-left: 10px;
        }

        .btn:hover { background: var(--accent-hover); transform: translateY(-1px); }
        .btn-success { background: var(--success); }
        .btn-success:hover { background: #059669; }
        .btn-warning { background: #f59e0b; }
        .btn-warning:hover { background: #d97706; }

        .container { display: flex; flex: 1; overflow: hidden; }

        .sidebar {
            width: 250px;
            background: var(--panel-bg);
            backdrop-filter: blur(10px);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
        }

        .file-list { list-style: none; overflow-y: auto; flex: 1; padding: 1rem 0; }
        .file-item {
            padding: 0.8rem 1.5rem;
            cursor: pointer;
            transition: background 0.2s;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .file-item:hover, .file-item.active {
            background: rgba(255, 255, 255, 0.05);
            border-left: 3px solid var(--accent);
        }

        .workspace {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: rgba(15, 23, 42, 0.3);
            position: relative;
        }

        .tabs {
            display: flex;
            border-bottom: 1px solid var(--border-color);
            background: rgba(0,0,0,0.2);
        }

        .tab {
            padding: 1rem 2rem;
            cursor: pointer;
            color: var(--text-muted);
            border-bottom: 2px solid transparent;
            transition: all 0.3s;
        }
        .tab.active {
            color: var(--text-main);
            border-bottom-color: var(--accent);
            background: rgba(255,255,255,0.02);
        }

        .tab-content { display: none; flex: 1; overflow-y: auto; padding: 2rem; }
        .tab-content.active { display: block; }

        /* Accordion Details */
        details {
            margin-bottom: 1rem;
            background: rgba(30, 41, 59, 0.5);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 0.5rem 1.5rem;
            transition: background 0.3s;
        }
        details[open] { background: rgba(30, 41, 59, 0.8); padding-bottom: 1.5rem; }
        
        summary.section-title {
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            padding: 1rem 0;
            list-style: none;
            display: flex;
            align-items: center;
            color: #e2e8f0;
            user-select: none;
        }
        summary::-webkit-details-marker { display: none; }
        summary::before {
            content: '▶';
            font-size: 0.8rem;
            margin-right: 12px;
            transition: transform 0.3s;
            color: var(--accent);
        }
        details[open] summary::before { transform: rotate(90deg); }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.5rem;
            margin-top: 1rem;
        }

        .card {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            backdrop-filter: blur(8px);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.3);
            border-color: rgba(255,255,255,0.2);
        }

        .card h3 {
            margin-bottom: 1rem;
            font-size: 1.05rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .tag-badge { background: rgba(59, 130, 246, 0.2); color: #93c5fd; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.75rem; }
        .tag-badge-group { background: rgba(16, 185, 129, 0.2); color: #6ee7b7; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.75rem; }
        .tag-badge-rule { background: rgba(168, 85, 247, 0.2); color: #d8b4fe; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.75rem; }

        .input-group { margin-bottom: 1rem; }
        .input-group:last-child { margin-bottom: 0; }
        .input-group label {
            display: block;
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 0.4rem;
        }
        .input-group input, .input-group textarea {
            width: 100%;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 0.6rem;
            border-radius: 6px;
            font-family: monospace;
            font-size: 0.85rem;
            transition: border-color 0.3s;
        }
        .input-group textarea {
            resize: vertical;
            min-height: 80px;
            line-height: 1.4;
        }
        .input-group input:focus, .input-group textarea:focus {
            outline: none;
            border-color: var(--accent);
        }

        #code-editor {
            width: 100%;
            height: 100%;
            background: #1e1e1e;
            color: #d4d4d4;
            font-family: 'Courier New', Courier, monospace;
            padding: 1.5rem;
            border: none;
            border-radius: 8px;
            resize: none;
        }
        #code-editor:focus { outline: none; }

        #welcome-screen {
            position: absolute;
            top: 60px; /* Leave space for toolbar */
            left: 0;
            right: 0;
            bottom: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: transparent;
            z-index: 5;
        }

        /* Unified Background Effects */
        .background-elements {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
            pointer-events: none;
        }
        .glow-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.4;
            animation: float 20s infinite ease-in-out;
        }
        .orb-1 {
            top: -10%;
            left: -10%;
            width: 50vw;
            height: 50vw;
            background: radial-gradient(circle, #3b82f6, transparent 60%);
        }
        .orb-2 {
            bottom: -20%;
            right: -10%;
            width: 60vw;
            height: 60vw;
            background: radial-gradient(circle, #8b5cf6, transparent 60%);
            animation-delay: -10s;
        }
        @keyframes float {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(5%, 5%); }
        }

        #file-drop-overlay {
            position: fixed;
            inset: 0;
            background: rgba(59, 130, 246, 0.2);
            backdrop-filter: blur(4px);
            z-index: 100;
            display: none;
            justify-content: center;
            align-items: center;
            border: 4px dashed var(--accent);
        }
        #file-drop-overlay h2 {
            font-size: 2rem;
            color: white;
            text-shadow: 0 2px 10px rgba(0,0,0,0.5);
            pointer-events: none;
        }

        #fallback-file-input { display: none; }
        
        .yaml-warning-text {
            color: var(--text-muted);
            font-size: 0.8rem;
            text-align: center;
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border-color);
            opacity: 0.7;
        }
        
        .drag-list { display: flex; flex-direction: column; gap: 0.5rem; max-height: 500px; overflow-y: auto; padding-right: 10px; }
        .drag-item { display: flex; align-items: center; background: rgba(0, 0, 0, 0.3); border: 1px solid var(--border-color); padding: 0.5rem; border-radius: 6px; gap: 10px; }
        .drag-item.sortable-ghost { opacity: 0.4; }
        .drag-handle { cursor: grab; color: var(--text-muted); padding: 0 5px; font-size: 1.2rem; user-select: none; }
        .drag-item input { flex: 1; background: transparent; border: none; color: var(--text-main); font-family: monospace; font-size: 0.85rem; outline: none; }
        .btn-del { background: none; border: none; color: var(--danger); cursor: pointer; font-size: 1rem; opacity: 0.7; transition: opacity 0.2s; }
        .btn-del:hover { opacity: 1; }
        .drag-list::-webkit-scrollbar { width: 8px; }
        .drag-list::-webkit-scrollbar-track { background: rgba(0,0,0,0.1); border-radius: 4px; }
        .drag-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 4px; }
        .drag-list::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.3); }
    </style>
</head>
<body>
    <div class="background-elements">
        <div class="glow-orb orb-1"></div>
        <div class="glow-orb orb-2"></div>
    </div>
    <div class="container" style="max-width: 1600px;">
        <nav>
            <a href="/" class="back-link">← Back to Hub</a>
        </nav>
        
        <header>
            <h1>Proxy Config <span class="highlight">Studio</span></h1>
            <p>支持 Sing-box (JSON) 和 Clash (YAML) 配置文件的可视化管理。</p>
        </header>

        <main class="tool-interface" style="flex-direction: row; align-items: stretch; height: 75vh; min-height: 600px; position: relative;">
            
            <!-- Sidebar Panel -->
            <div class="panel" style="width: 300px; padding: 1.5rem 1rem; overflow: hidden;">
                <div class="panel-header" style="margin-bottom: 1rem; padding: 0 0.5rem;">
                    <h2 style="font-size: 1.1rem;">Files</h2>
                    <div class="actions">
                        <button id="btn-open-dir" class="btn icon-btn" title="Open Folder">📂 Open</button>
                        <input type="file" id="fallback-file-input" accept=".json,.yaml,.yml" style="display: none;" />
                        <button id="btn-fallback-open" class="btn icon-btn" style="display: none;" title="Open File">📂 Open</button>
                    </div>
                </div>
                <ul class="file-list" id="file-list" style="overflow-y: auto; flex: 1; padding: 0 0.5rem;"></ul>
            </div>

            <!-- Workspace Panel -->
            <div class="panel" style="flex: 1; overflow: hidden; padding: 0; display: flex; flex-direction: column; gap: 0;">
                <div class="panel-header" style="padding: 1.5rem; border-bottom: 1px solid var(--border-color); background: rgba(0,0,0,0.2);">
                    <div class="tabs" style="display: flex; gap: 1rem;">
                        <div class="tab active" data-target="tab-visual" style="font-size: 1.1rem; font-weight: 600; cursor: pointer;">✨ Visual Config</div>
                        <div class="tab" data-target="tab-code" style="font-size: 1.1rem; font-weight: 600; cursor: pointer;">💻 Source Code</div>
                    </div>
                    <div class="actions">
                        <button id="btn-save-as" class="btn secondary" style="display: none;">Save As...</button>
                        <button id="btn-save" class="btn primary" style="display: none;">Save Config</button>
                    </div>
                </div>

                <div class="workspace-content" id="workspace" style="display: none; flex: 1; overflow: hidden;">
                    <div class="tab-content active" id="tab-visual" style="height: 100%; overflow-y: auto; padding: 2rem;">
                <!-- SINGBOX CONTAINERS -->
                <div id="singbox-sections">
                    <details>
                        <summary class="section-title">入站配置 (Inbounds)</summary>
                        <div class="card-grid" id="inbounds-grid"></div>
                    </details>
                    <details>
                        <summary class="section-title">DNS 服务器 (DNS Servers)</summary>
                        <div class="card-grid" id="dns-servers-grid"></div>
                    </details>
                    <details>
                        <summary class="section-title">DNS 规则 (DNS Rules)</summary>
                        <div class="card-grid" id="dns-rules-grid"></div>
                    </details>
                    <details>
                        <summary class="section-title">路由规则 (Route Rules)</summary>
                        <div class="card-grid" id="route-rules-grid"></div>
                    </details>
                    <details>
                        <summary class="section-title">分流策略组 (Outbounds: Groups)</summary>
                        <div class="card-grid" id="groups-grid"></div>
                    </details>
                    <details>
                        <summary class="section-title">代理节点 (Outbounds: Proxies)</summary>
                        <div class="card-grid" id="nodes-grid"></div>
                    </details>
                </div>
                
                <div id="clash-sections" style="display:none;">
                    <details>
                        <summary class="section-title">分流规则 (Rules)</summary>
                        <div id="clash-rules-card" style="margin-top: 1rem; margin-left: 1.5rem; margin-right: 1.5rem; margin-bottom: 1rem;"></div>
                    </details>
                    <details>
                        <summary class="section-title">分流策略组 (Proxy Groups)</summary>
                        <div class="card-grid" id="clash-groups-grid"></div>
                    </details>
                    <details>
                        <summary class="section-title">代理节点 (Proxies)</summary>
                        <div class="card-grid" id="clash-nodes-grid"></div>
                    </details>
                </div>
                
                <div id="yaml-warning" class="yaml-warning-text" style="display:none;">
                    * 修改并保存 YAML 文件时，由于引擎限制，文件中的部分注释文本 (#) 可能会被丢弃。
                </div>
            </div> <!-- End tab-visual -->

            <div class="tab-content" id="tab-code" style="padding: 0; height: 100%;">
                <textarea id="code-editor" style="width: 100%; height: 100%; background: #1e1e1e; border: none; border-radius: 0; color: #fff;"></textarea>
            </div>
        </div> <!-- End workspace -->

        <!-- Welcome Screen Overlay inside the workspace panel -->
        <div id="welcome-screen" style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--surface-color); z-index: 5;">
            <h2 style="font-size: 1.5rem; color: var(--text-muted); margin-bottom: 1.5rem;">请在左侧选择文件夹或文件以开始配置</h2>
            <button class="btn secondary" id="btn-main-action">点击或拖拽文件到此处打开</button>
        </div>
    </div> <!-- End workspace Panel -->
</main>
</div> <!-- End container -->

    <div id="file-drop-overlay"><h2>📥 松开鼠标打开文件</h2></div>

    <script>
        let directoryHandle;
        let currentFileHandle = null;
        let configData = null;
        let currentFileName = "config.json";
        let isClash = false;
        
        const isFSApiSupported = 'showDirectoryPicker' in window;

        const btnOpenDir = document.getElementById('btn-open-dir');
        const btnFallbackOpen = document.getElementById('btn-fallback-open');
        const fallbackFileInput = document.getElementById('fallback-file-input');
        const btnSave = document.getElementById('btn-save');
        const btnSaveAs = document.getElementById('btn-save-as');
        const btnMainAction = document.getElementById('btn-main-action');
        
        const fileList = document.getElementById('file-list');
        const sidebar = document.getElementById('sidebar');
        const workspace = document.getElementById('workspace');
        const welcomeScreen = document.getElementById('welcome-screen');
        const codeEditor = document.getElementById('code-editor');

        // Setup UI based on browser support
        if (!isFSApiSupported) {
            btnOpenDir.style.display = 'none';
            btnFallbackOpen.style.display = 'inline-block';
            sidebar.style.display = 'none';
            // User requested to hide Save As in Safari mode
            btnSaveAs.style.display = 'none'; 
            btnSave.innerText = '💾 保存并下载';
        }

        // Tab Switching
        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById(tab.dataset.target).classList.add('active');
                
                if(tab.dataset.target === 'tab-visual') {
                    try {
                        configData = isClash ? jsyaml.load(codeEditor.value) : JSON.parse(codeEditor.value);
                        renderVisualEditor();
                    } catch(e) {
                        alert("文件格式错误，无法生成可视化界面！请在代码模式下修复。");
                        document.querySelector('[data-target="tab-code"]').click();
                    }
                }
            });
        });

        const handleOpenDirectory = async () => {
            try {
                directoryHandle = await window.showDirectoryPicker({ mode: 'readwrite' });
                await loadFileList();
                welcomeScreen.style.display = 'none';
                workspace.style.display = 'flex';
            } catch (err) { }
        };

        btnOpenDir.addEventListener('click', handleOpenDirectory);
        if(isFSApiSupported) btnMainAction.addEventListener('click', handleOpenDirectory);

        async function loadFileList() {
            fileList.innerHTML = '';
            for await (const entry of directoryHandle.values()) {
                if (entry.kind === 'file' && (entry.name.endsWith('.json') || entry.name.endsWith('.yaml') || entry.name.endsWith('.yml'))) {
                    const li = document.createElement('li');
                    li.className = 'file-item';
                    li.innerHTML = `📄 ${entry.name}`;
                    li.onclick = () => loadFile(entry, li);
                    fileList.appendChild(li);
                }
            }
        }

        async function loadFile(fileHandle, listItem) {
            document.querySelectorAll('.file-item').forEach(el => el.classList.remove('active'));
            listItem.classList.add('active');
            currentFileHandle = fileHandle;
            currentFileName = fileHandle.name;
            btnSave.style.display = 'inline-block';
            if(isFSApiSupported) btnSaveAs.style.display = 'inline-block';

            const file = await fileHandle.getFile();
            const text = await file.text();
            processFileContent(text, currentFileName);
        }

        const handleFallbackOpen = () => fallbackFileInput.click();
        btnFallbackOpen.addEventListener('click', handleFallbackOpen);
        if(!isFSApiSupported) btnMainAction.addEventListener('click', handleFallbackOpen);

        fallbackFileInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (!file) return;
            currentFileName = file.name;
            btnSave.style.display = 'inline-block';
            // No Save As button needed for Safari mode as requested
            
            const reader = new FileReader();
            reader.onload = (ev) => {
                processFileContent(ev.target.result, currentFileName);
                welcomeScreen.style.display = 'none';
                workspace.style.display = 'flex';
            };
            reader.readAsText(file);
            fallbackFileInput.value = '';
        });

        // Global Drag and Drop for Files
        const dropOverlay = document.getElementById('file-drop-overlay');
        
        window.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropOverlay.style.display = 'flex';
        });
        
        window.addEventListener('dragleave', (e) => {
            e.preventDefault();
            if (e.target === dropOverlay) dropOverlay.style.display = 'none';
        });
        
        window.addEventListener('drop', async (e) => {
            e.preventDefault();
            dropOverlay.style.display = 'none';
            
            const file = e.dataTransfer.files[0];
            if (!file) return;
            
            currentFileName = file.name;
            btnSave.style.display = 'inline-block';
            
            if (isFSApiSupported) {
                const item = e.dataTransfer.items[0];
                if (item && item.getAsFileSystemHandle) {
                    try {
                        const handle = await item.getAsFileSystemHandle();
                        if (handle && handle.kind === 'file') {
                            currentFileHandle = handle;
                            btnSaveAs.style.display = 'inline-block';
                        }
                    } catch(err){}
                } else {
                    currentFileHandle = null;
                }
            }
            
            const reader = new FileReader();
            reader.onload = (ev) => {
                processFileContent(ev.target.result, currentFileName);
                welcomeScreen.style.display = 'none';
                workspace.style.display = 'flex';
            };
            reader.readAsText(file);
        });

        function processFileContent(text, fileName) {
            codeEditor.value = text;
            try {
                if(fileName.endsWith('.yaml') || fileName.endsWith('.yml')) {
                    configData = jsyaml.load(text);
                    isClash = true;
                    renderVisualEditor();
                    document.querySelector('[data-target="tab-visual"]').click();
                } else if(fileName.endsWith('.json')){
                    configData = JSON.parse(text);
                    isClash = false;
                    renderVisualEditor();
                    document.querySelector('[data-target="tab-visual"]').click();
                } else {
                    document.querySelector('[data-target="tab-code"]').click();
                }
            } catch(e) {
                document.querySelector('[data-target="tab-code"]').click();
            }
        }

        function arrayToText(arr) {
            if (!arr) return "";
            if (Array.isArray(arr)) return arr.join('\n');
            return arr.toString();
        }

        function renderVisualEditor() {
            if (!configData) return;
            
            if (isClash) {
                document.getElementById('singbox-sections').style.display = 'none';
                document.getElementById('clash-sections').style.display = 'block';
                document.getElementById('yaml-warning').style.display = 'block';
                
                const groupsGrid = document.getElementById('clash-groups-grid');
                const nodesGrid = document.getElementById('clash-nodes-grid');
                const rulesCard = document.getElementById('clash-rules-card');
                groupsGrid.innerHTML = '';
                nodesGrid.innerHTML = '';
                
                // Clash Rules
                if (configData.rules) {
                    rulesCard.innerHTML = `
                        <div class="card" style="width:100%;">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
                                <h3>全局分流规则 <span class="tag-badge-rule">RULES</span></h3>
                                <button class="btn" id="btn-add-rule" style="padding:0.3rem 0.8rem; font-size:0.8rem;">➕ 插入新规则</button>
                            </div>
                            <div class="input-group">
                                <label style="margin-bottom:1rem;">拖拽左侧 ☰ 即可排序，修改立即生效</label>
                                <div id="clash-rules-list" class="drag-list"></div>
                            </div>
                        </div>
                    `;
                    
                    const rulesList = document.getElementById('clash-rules-list');
                    configData.rules.forEach((rule, idx) => {
                        const item = document.createElement('div');
                        item.className = 'drag-item';
                        item.innerHTML = `
                            <span class="drag-handle" title="拖拽排序">☰</span>
                            <input type="text" data-sec="rules-item" data-idx="${idx}" value="${rule}">
                            <button class="btn-del" data-action="del-rule" data-idx="${idx}" title="删除此规则">✖</button>
                        `;
                        rulesList.appendChild(item);
                    });

                    new Sortable(rulesList, {
                        handle: '.drag-handle',
                        animation: 150,
                        ghostClass: 'sortable-ghost',
                        onEnd: function (evt) {
                            const item = configData.rules.splice(evt.oldIndex, 1)[0];
                            configData.rules.splice(evt.newIndex, 0, item);
                            codeEditor.value = jsyaml.dump(configData, { lineWidth: -1 });
                            renderVisualEditor();
                        }
                    });
                    
                    document.getElementById('btn-add-rule').onclick = () => {
                        configData.rules.unshift("DOMAIN-SUFFIX,example.com,DIRECT");
                        codeEditor.value = jsyaml.dump(configData, { lineWidth: -1 });
                        renderVisualEditor();
                    };
                } else {
                    rulesCard.innerHTML = '<p style="color:var(--text-muted);">当前配置无分流规则或解析失败</p>';
                }

                // Clash Proxy Groups
                if (configData['proxy-groups']) {
                    configData['proxy-groups'].forEach((group, i) => {
                        const card = document.createElement('div');
                        card.className = 'card';
                        card.innerHTML = `
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 1rem;">
                                <h3 style="margin-bottom:0;">${group.name}</h3>
                                <select data-sec="proxy-groups" data-idx="${i}" data-key="type" style="background:rgba(0,0,0,0.5); color:var(--text-main); border:1px solid var(--accent); padding:0.3rem 0.6rem; border-radius:6px; font-size:0.85rem; outline:none; cursor:pointer;">
                                    <option value="select" ${group.type === 'select' ? 'selected' : ''}>SELECT (手动)</option>
                                    <option value="url-test" ${group.type === 'url-test' ? 'selected' : ''}>URL-TEST (自动)</option>
                                    <option value="fallback" ${group.type === 'fallback' ? 'selected' : ''}>FALLBACK (主备)</option>
                                </select>
                            </div>
                            <div class="input-group">
                                <label>包含的节点/组 (每行一个)</label>
                                <textarea data-sec="proxy-groups" data-idx="${i}" data-key="proxies">${arrayToText(group.proxies)}</textarea>
                            </div>
                        `;
                        groupsGrid.appendChild(card);
                    });
                }
                
                // Clash Proxies
                if (configData.proxies) {
                    configData.proxies.forEach((proxy, i) => {
                        const card = document.createElement('div');
                        card.className = 'card';
                        card.innerHTML = `
                            <h3>${proxy.name} <span class="tag-badge">${(proxy.type || '').toUpperCase()}</span></h3>
                            <div class="input-group">
                                <label>服务器 (Server / IP)</label>
                                <input type="text" data-sec="proxies" data-idx="${i}" data-key="server" value="${proxy.server || ''}">
                            </div>
                            <div class="input-group">
                                <label>端口 (Port)</label>
                                <input type="number" data-sec="proxies" data-idx="${i}" data-key="port" value="${proxy.port || ''}">
                            </div>
                        `;
                        nodesGrid.appendChild(card);
                    });
                }
                
            } else {
                document.getElementById('singbox-sections').style.display = 'block';
                document.getElementById('clash-sections').style.display = 'none';
                document.getElementById('yaml-warning').style.display = 'none';
                
                const renderGrid = (id, items, renderFn) => {
                    const grid = document.getElementById(id);
                    grid.innerHTML = '';
                    if(items) items.forEach((item, idx) => grid.appendChild(renderFn(item, idx)));
                };

                renderGrid('inbounds-grid', configData.inbounds, (ob, i) => {
                    const card = document.createElement('div');
                    card.className = 'card';
                    card.innerHTML = `
                        <h3>${ob.tag || 'Unnamed'} <span class="tag-badge">${(ob.type||'').toUpperCase()}</span></h3>
                        <div class="input-group"><label>Listen (监听地址)</label><input type="text" data-sec="inbounds" data-idx="${i}" data-key="listen" value="${ob.listen || ''}"></div>
                        <div class="input-group"><label>Listen Port (监听端口)</label><input type="number" data-sec="inbounds" data-idx="${i}" data-key="listen_port" value="${ob.listen_port || ''}"></div>
                    `;
                    return card;
                });

                renderGrid('dns-servers-grid', configData.dns?.servers, (ds, i) => {
                    const card = document.createElement('div');
                    card.className = 'card';
                    card.innerHTML = `
                        <h3>${ds.tag || 'Unnamed'} <span class="tag-badge">${(ds.type||'').toUpperCase()}</span></h3>
                        <div class="input-group"><label>Server/Address (服务器地址)</label><input type="text" data-sec="dns.servers" data-idx="${i}" data-key="server" value="${ds.server || ds.address || ''}"></div>
                    `;
                    return card;
                });

                renderGrid('dns-rules-grid', configData.dns?.rules, (r, i) => {
                    const card = document.createElement('div');
                    card.className = 'card';
                    let matchersHtml = '';
                    for (let k in r) {
                        if (k === 'server') continue;
                        matchersHtml += `<div class="input-group"><label>${k} (匹配规则)</label><textarea data-sec="dns.rules" data-idx="${i}" data-key="${k}">${arrayToText(r[k])}</textarea></div>`;
                    }
                    card.innerHTML = `
                        <h3>Rule #${i+1} <span class="tag-badge-rule">DNS RULE</span></h3>
                        ${matchersHtml || '<p style="color:var(--text-muted);font-size:0.8rem;margin-bottom:1rem;">(全局默认规则)</p>'}
                        <div class="input-group"><label>目标 DNS (server)</label><input type="text" data-sec="dns.rules" data-idx="${i}" data-key="server" value="${r.server || ''}"></div>
                    `;
                    return card;
                });

                renderGrid('route-rules-grid', configData.route?.rules, (r, i) => {
                    const card = document.createElement('div');
                    card.className = 'card';
                    let matchersHtml = '';
                    for (let k in r) {
                        if (k === 'outbound') continue;
                        matchersHtml += `<div class="input-group"><label>${k} (匹配规则)</label><textarea data-sec="route.rules" data-idx="${i}" data-key="${k}">${arrayToText(r[k])}</textarea></div>`;
                    }
                    card.innerHTML = `
                        <h3>Rule #${i+1} <span class="tag-badge-rule">ROUTE RULE</span></h3>
                        ${matchersHtml || '<p style="color:var(--text-muted);font-size:0.8rem;margin-bottom:1rem;">(全局默认规则)</p>'}
                        <div class="input-group"><label>目标出站组/节点 (outbound)</label><input type="text" data-sec="route.rules" data-idx="${i}" data-key="outbound" value="${r.outbound || ''}"></div>
                    `;
                    return card;
                });

                const groupsGrid = document.getElementById('groups-grid');
                const nodesGrid = document.getElementById('nodes-grid');
                groupsGrid.innerHTML = '';
                nodesGrid.innerHTML = '';
                
                if (configData.outbounds) {
                    configData.outbounds.forEach((ob, i) => {
                        const card = document.createElement('div');
                        card.className = 'card';
                        
                        if (['selector', 'urltest'].includes(ob.type)) {
                            card.innerHTML = `
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 1rem;">
                                    <h3 style="margin-bottom:0;">${ob.tag}</h3>
                                    <select data-sec="outbounds" data-idx="${i}" data-key="type" style="background:rgba(0,0,0,0.5); color:var(--text-main); border:1px solid var(--accent); padding:0.3rem 0.6rem; border-radius:6px; font-size:0.85rem; outline:none; cursor:pointer;">
                                        <option value="selector" ${ob.type === 'selector' ? 'selected' : ''}>SELECTOR (手动选择)</option>
                                        <option value="urltest" ${ob.type === 'urltest' ? 'selected' : ''}>URLTEST (自动测速)</option>
                                    </select>
                                </div>
                                <div class="input-group"><label>包含的节点/组 (每行一个)</label><textarea data-sec="outbounds" data-idx="${i}" data-key="outbounds">${arrayToText(ob.outbounds)}</textarea></div>
                            `;
                            groupsGrid.appendChild(card);
                        } else if (['vless', 'trojan', 'shadowsocks', 'vmess', 'hysteria2', 'tuic'].includes(ob.type)) {
                            let proxyIp = "";
                            if(ob.transport && ob.transport.path && ob.transport.path.includes('proxyip=')) {
                                proxyIp = ob.transport.path.split('proxyip=')[1].split('&')[0];
                            }
                            card.innerHTML = `
                                <h3>${ob.tag} <span class="tag-badge">${ob.type.toUpperCase()}</span></h3>
                                <div class="input-group"><label>服务器 (Server)</label><input type="text" data-sec="outbounds" data-idx="${i}" data-key="server" value="${ob.server || ''}"></div>
                                <div class="input-group"><label>端口 (Port)</label><input type="number" data-sec="outbounds" data-idx="${i}" data-key="server_port" value="${ob.server_port || ''}"></div>
                                ${ob.transport && ob.transport.type === 'ws' ? `<div class="input-group"><label>Proxy IP (用于跳板)</label><input type="text" data-sec="outbounds" data-idx="${i}" data-key="proxyip" value="${proxyIp}"></div>` : ''}
                            `;
                            nodesGrid.appendChild(card);
                        }
                    });
                }
            }

            // Delete Rules Listener
            document.querySelectorAll('.btn-del').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const idx = e.target.dataset.idx;
                    configData.rules.splice(idx, 1);
                    codeEditor.value = jsyaml.dump(configData, { lineWidth: -1 });
                    renderVisualEditor();
                });
            });

            // Universal Listener
            document.querySelectorAll('#tab-visual input, #tab-visual textarea, #tab-visual select').forEach(el => {
                el.addEventListener('change', (e) => {
                    const sec = e.target.dataset.sec;
                    const idx = e.target.dataset.idx;
                    const key = e.target.dataset.key;
                    let val = e.target.value;
                    
                    if (e.target.type === 'number') val = parseInt(val);
                    else if (e.target.tagName === 'TEXTAREA') {
                        val = val.split('\n').map(s => s.trim()).filter(s => s !== "");
                        if(val.length === 0) val = undefined;
                    }

                    let targetObj;
                    if (isClash) {
                        if (sec === 'rules-item') {
                            configData.rules[idx] = val;
                            codeEditor.value = jsyaml.dump(configData, { lineWidth: -1 });
                            return;
                        }
                        if (sec === 'proxy-groups') targetObj = configData['proxy-groups'][idx];
                        else if (sec === 'proxies') targetObj = configData.proxies[idx];
                    } else {
                        if(sec === 'inbounds') targetObj = configData.inbounds[idx];
                        else if(sec === 'dns.servers') targetObj = configData.dns.servers[idx];
                        else if(sec === 'dns.rules') targetObj = configData.dns.rules[idx];
                        else if(sec === 'route.rules') targetObj = configData.route.rules[idx];
                        else if(sec === 'outbounds') targetObj = configData.outbounds[idx];
                    }

                    if (targetObj) {
                        if (key === 'proxyip' && targetObj.transport) {
                            let path = targetObj.transport.path;
                            if(path.includes('proxyip=')) targetObj.transport.path = path.replace(/proxyip=[^&]+/, 'proxyip=' + val);
                            else targetObj.transport.path = path + (path.includes('?') ? '&' : '?') + 'proxyip=' + val;
                        } 
                        else if (key === 'server' && targetObj.address !== undefined) {
                            targetObj.address = val;
                        }
                        else if (key === 'type' && !isClash) {
                            targetObj.type = val;
                            if (val === 'selector') {
                                delete targetObj.url; delete targetObj.interval; delete targetObj.tolerance;
                            } else if (val === 'urltest') {
                                delete targetObj.default;
                                if (!targetObj.url) targetObj.url = "https://www.gstatic.com/generate_204";
                                if (!targetObj.interval) targetObj.interval = "3m";
                            }
                        }
                        else if (key === 'type' && isClash) {
                            targetObj.type = val;
                            if (val === 'select') {
                                delete targetObj.url; delete targetObj.interval; delete targetObj.tolerance;
                            } else if (val === 'url-test' || val === 'fallback') {
                                if (!targetObj.url) targetObj.url = "http://www.gstatic.com/generate_204";
                                if (!targetObj.interval) targetObj.interval = 300;
                            }
                        }
                        else {
                            if (val === undefined) delete targetObj[key];
                            else targetObj[key] = val;
                        }
                    }

                    codeEditor.value = isClash ? jsyaml.dump(configData, { lineWidth: -1 }) : JSON.stringify(configData, null, 2);
                });
            });
        }

        async function triggerDownload(content, filename) {
            const blob = new Blob([content], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        btnSave.addEventListener('click', async () => {
            const content = codeEditor.value;
            if (isFSApiSupported && currentFileHandle) {
                try {
                    const writable = await currentFileHandle.createWritable();
                    await writable.write(content);
                    await writable.close();
                    const originalText = btnSave.innerText;
                    btnSave.innerText = "✅ 保存成功!";
                    setTimeout(() => btnSave.innerText = originalText, 2000);
                } catch (err) { alert("保存失败！无权限。"); }
            } else {
                triggerDownload(content, currentFileName);
                const originalText = btnSave.innerText;
                btnSave.innerText = "✅ 已触发下载";
                setTimeout(() => btnSave.innerText = originalText, 2000);
            }
        });

        if (btnSaveAs) {
            btnSaveAs.addEventListener('click', async () => {
                const content = codeEditor.value;
                if (isFSApiSupported) {
                    try {
                        const newHandle = await window.showSaveFilePicker({
                            suggestedName: currentFileName,
                            types: [{ description: 'Config File', accept: {'text/plain': ['.json', '.yaml', '.yml']} }]
                        });
                        const writable = await newHandle.createWritable();
                        await writable.write(content);
                        await writable.close();
                        const originalText = btnSaveAs.innerText;
                        btnSaveAs.innerText = "✅ 另存为成功!";
                        setTimeout(() => btnSaveAs.innerText = originalText, 2000);
                    } catch (err) {}
                }
            });
        }
    </script>
</body>
</html>
