<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Proxy Config Studio (Sing-box & Clash)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/base64-style.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/js-yaml/4.1.0/js-yaml.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <style>
        /* Alias local names to the global design tokens in style.css */
        :root {
            --accent: var(--accent-color);
            --text-main: var(--text-primary);
            --text-muted: var(--text-secondary);
            --danger: #ef4444;
            --success: #10b981;
        }

        /* --- Dropzone (initial state) --- */
        .dropzone {
            border: 2px dashed var(--border-color);
            border-radius: 12px;
            padding: 3rem 2rem;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
            color: var(--text-secondary);
            transition: border-color 0.2s, background 0.2s;
            cursor: pointer;
        }
        .dropzone:hover, .dropzone.dragover {
            border-color: var(--accent-color);
            background: rgba(59, 130, 246, 0.06);
        }
        .dropzone .dropzone-icon { font-size: 2.5rem; opacity: 0.8; }
        .dropzone p { font-size: 0.95rem; }
        .dropzone .hint { font-size: 0.8rem; opacity: 0.6; }

        /* --- Workspace panel --- */
        .workspace-panel { padding: 0; gap: 0; overflow: hidden; }
        .workspace-panel .panel-header {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            background: rgba(0, 0, 0, 0.15);
        }
        .file-badge {
            color: var(--text-secondary);
            font-size: 0.85rem;
            font-family: monospace;
            margin-right: 0.5rem;
        }

        /* --- Tabs --- */
        .tabs { display: flex; gap: 0.5rem; }
        .tab {
            padding: 0.4rem 0.9rem;
            cursor: pointer;
            color: var(--text-secondary);
            background: transparent;
            border: 1px solid transparent;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 500;
            transition: all 0.2s;
        }
        .tab:hover { color: var(--text-primary); }
        .tab.active {
            color: var(--text-primary);
            background: rgba(255, 255, 255, 0.06);
            border-color: var(--border-color);
        }

        .tab-content { display: none; max-height: 70vh; overflow-y: auto; }
        .tab-content.active { display: block; }
        #tab-visual { padding: 1.5rem; }
        #tab-code { padding: 0; }

        /* --- Accordion sections --- */
        details {
            margin-bottom: 1rem;
            background: rgba(30, 41, 59, 0.5);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 0.5rem 1.5rem;
            transition: background 0.3s;
        }
        details[open] { background: rgba(30, 41, 59, 0.8); padding-bottom: 1.5rem; }
        summary.section-title {
            font-size: 1.05rem;
            font-weight: 600;
            cursor: pointer;
            padding: 1rem 0;
            list-style: none;
            display: flex;
            align-items: center;
            color: #e2e8f0;
            user-select: none;
        }
        summary::-webkit-details-marker { display: none; }
        summary::before {
            content: '▶';
            font-size: 0.8rem;
            margin-right: 12px;
            transition: transform 0.3s;
            color: var(--accent);
        }
        details[open] summary::before { transform: rotate(90deg); }

        /* --- Cards --- */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.5rem;
            margin-top: 1rem;
        }
        .card {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            backdrop-filter: blur(8px);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
            border-color: rgba(255, 255, 255, 0.2);
        }
        .card h3 {
            margin-bottom: 1rem;
            font-size: 1.05rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .tag-badge { background: rgba(59, 130, 246, 0.2); color: #93c5fd; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.75rem; }
        .tag-badge-group { background: rgba(16, 185, 129, 0.2); color: #6ee7b7; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.75rem; }
        .tag-badge-rule { background: rgba(168, 85, 247, 0.2); color: #d8b4fe; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.75rem; }

        .input-group { margin-bottom: 1rem; }
        .input-group:last-child { margin-bottom: 0; }
        .input-group label { display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.4rem; }
        .input-group input, .input-group textarea {
            width: 100%;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 0.6rem;
            border-radius: 6px;
            font-family: monospace;
            font-size: 0.85rem;
            transition: border-color 0.3s;
        }
        .input-group textarea { resize: vertical; min-height: 80px; line-height: 1.4; }
        .input-group input:focus, .input-group textarea:focus { outline: none; border-color: var(--accent); }

        #code-editor {
            width: 100%;
            height: 70vh;
            background: #1e1e1e;
            color: #d4d4d4;
            font-family: 'Courier New', Courier, monospace;
            font-size: 0.9rem;
            line-height: 1.5;
            padding: 1.5rem;
            border: none;
            border-radius: 0;
            resize: none;
        }
        #code-editor:focus { outline: none; }

        .yaml-warning-text {
            color: var(--text-muted);
            font-size: 0.8rem;
            text-align: center;
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border-color);
            opacity: 0.7;
        }

        /* --- Drag list (Clash rules) --- */
        .drag-list { display: flex; flex-direction: column; gap: 0.5rem; max-height: 500px; overflow-y: auto; padding-right: 10px; }
        .drag-item { display: flex; align-items: center; background: rgba(0, 0, 0, 0.3); border: 1px solid var(--border-color); padding: 0.5rem; border-radius: 6px; gap: 10px; }
        .drag-item.sortable-ghost { opacity: 0.4; }
        .drag-handle { cursor: grab; color: var(--text-muted); padding: 0 5px; font-size: 1.2rem; user-select: none; }
        .drag-item input { flex: 1; background: transparent; border: none; color: var(--text-main); font-family: monospace; font-size: 0.85rem; outline: none; }
        .btn-del { background: none; border: none; color: var(--danger); cursor: pointer; font-size: 1rem; opacity: 0.7; transition: opacity 0.2s; }
        .btn-del:hover { opacity: 1; }
        .drag-list::-webkit-scrollbar { width: 8px; }
        .drag-list::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.1); border-radius: 4px; }
        .drag-list::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.2); border-radius: 4px; }
        .drag-list::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.3); }

        /* --- Global drop overlay --- */
        #file-drop-overlay {
            position: fixed;
            inset: 0;
            background: rgba(59, 130, 246, 0.2);
            backdrop-filter: blur(4px);
            z-index: 100;
            display: none;
            justify-content: center;
            align-items: center;
            border: 4px dashed var(--accent);
        }
        #file-drop-overlay h2 {
            font-size: 2rem;
            color: white;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
            pointer-events: none;
        }
    </style>
</head>
<body>
    <div class="background-elements">
        <div class="glow-orb orb-1"></div>
        <div class="glow-orb orb-2"></div>
    </div>

    <div class="container" style="max-width: 1400px;">
        <nav>
            <a href="/" class="back-link">← Back to Hub</a>
        </nav>

        <header>
            <h1>Proxy Config <span class="highlight">Studio</span></h1>
            <p>可视化管理 Sing-box (JSON) 与 Clash (YAML) 配置文件。</p>
        </header>

        <main class="tool-interface">
            <!-- Initial state: drop / pick a file -->
            <div class="panel" id="dropzone-panel">
                <div class="dropzone" id="dropzone">
                    <div class="dropzone-icon">📥</div>
                    <p>拖入 JSON / YAML 配置文件，或点击选择文件</p>
                    <button class="btn secondary" id="btn-open">选择文件</button>
                    <span class="hint">所有解析与编辑均在浏览器本地完成，文件不会上传。</span>
                </div>
            </div>

            <!-- Editor state: hidden until a file is loaded -->
            <div class="panel workspace-panel" id="workspace-panel" style="display: none;">
                <div class="panel-header">
                    <div class="tabs">
                        <button class="tab active" data-target="tab-visual">✨ 可视化</button>
                        <button class="tab" data-target="tab-code">💻 源文件</button>
                    </div>
                    <div class="actions">
                        <span class="file-badge" id="file-badge"></span>
                        <button id="btn-load" class="btn secondary">📂 载入文件</button>
                        <button id="btn-save" class="btn primary">💾 保存</button>
                    </div>
                </div>

                <!-- Visual editor -->
                <div class="tab-content active" id="tab-visual">
                    <div id="singbox-sections">
                        <details>
                            <summary class="section-title">入站配置 (Inbounds)</summary>
                            <div class="card-grid" id="inbounds-grid"></div>
                        </details>
                        <details>
                            <summary class="section-title">DNS 服务器 (DNS Servers)</summary>
                            <div class="card-grid" id="dns-servers-grid"></div>
                        </details>
                        <details>
                            <summary class="section-title">DNS 规则 (DNS Rules)</summary>
                            <div class="card-grid" id="dns-rules-grid"></div>
                        </details>
                        <details>
                            <summary class="section-title">路由规则 (Route Rules)</summary>
                            <div class="card-grid" id="route-rules-grid"></div>
                        </details>
                        <details>
                            <summary class="section-title">分流策略组 (Outbounds: Groups)</summary>
                            <div class="card-grid" id="groups-grid"></div>
                        </details>
                        <details>
                            <summary class="section-title">代理节点 (Outbounds: Proxies)</summary>
                            <div class="card-grid" id="nodes-grid"></div>
                        </details>
                    </div>

                    <div id="clash-sections" style="display: none;">
                        <details>
                            <summary class="section-title">分流规则 (Rules)</summary>
                            <div id="clash-rules-card" style="margin: 1rem 1.5rem;"></div>
                        </details>
                        <details>
                            <summary class="section-title">分流策略组 (Proxy Groups)</summary>
                            <div class="card-grid" id="clash-groups-grid"></div>
                        </details>
                        <details>
                            <summary class="section-title">代理节点 (Proxies)</summary>
                            <div class="card-grid" id="clash-nodes-grid"></div>
                        </details>
                    </div>

                    <div id="yaml-warning" class="yaml-warning-text" style="display: none;">
                        * 修改并保存 YAML 文件时，由于引擎限制，文件中的部分注释文本 (#) 可能会被丢弃。
                    </div>
                </div>

                <!-- Source editor -->
                <div class="tab-content" id="tab-code">
                    <textarea id="code-editor" spellcheck="false"></textarea>
                </div>
            </div>
        </main>
    </div>

    <input type="file" id="file-input" accept=".json,.yaml,.yml" hidden />
    <div id="file-drop-overlay"><h2>📥 松开鼠标打开文件</h2></div>

    <script>
        let currentFileHandle = null;
        let configData = null;
        let currentFileName = "config.json";
        let isClash = false;

        const isFSApiSupported = 'showOpenFilePicker' in window;
        const FILE_TYPES = [{ description: 'Config File', accept: { 'text/plain': ['.json', '.yaml', '.yml'] } }];

        const btnOpen = document.getElementById('btn-open');
        const btnLoad = document.getElementById('btn-load');
        const btnSave = document.getElementById('btn-save');
        const fileInput = document.getElementById('file-input');
        const dropzone = document.getElementById('dropzone');
        const dropzonePanel = document.getElementById('dropzone-panel');
        const workspacePanel = document.getElementById('workspace-panel');
        const fileBadge = document.getElementById('file-badge');
        const codeEditor = document.getElementById('code-editor');

        // --- File opening ---
        async function openFilePicker() {
            if (isFSApiSupported) {
                try {
                    const [handle] = await window.showOpenFilePicker({ types: FILE_TYPES, multiple: false });
                    currentFileHandle = handle;
                    const file = await handle.getFile();
                    loadContent(await file.text(), file.name);
                } catch (err) { /* user cancelled */ }
            } else {
                fileInput.click();
            }
        }

        btnOpen.addEventListener('click', openFilePicker);
        btnLoad.addEventListener('click', openFilePicker);
        dropzone.addEventListener('click', openFilePicker);

        fileInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (!file) return;
            currentFileHandle = null;
            const reader = new FileReader();
            reader.onload = (ev) => loadContent(ev.target.result, file.name);
            reader.readAsText(file);
            fileInput.value = '';
        });

        // --- Global drag & drop ---
        const dropOverlay = document.getElementById('file-drop-overlay');

        window.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropOverlay.style.display = 'flex';
        });
        window.addEventListener('dragleave', (e) => {
            e.preventDefault();
            if (e.target === dropOverlay) dropOverlay.style.display = 'none';
        });
        window.addEventListener('drop', async (e) => {
            e.preventDefault();
            dropOverlay.style.display = 'none';

            const file = e.dataTransfer.files[0];
            if (!file) return;

            currentFileHandle = null;
            if (isFSApiSupported) {
                const item = e.dataTransfer.items[0];
                if (item && item.getAsFileSystemHandle) {
                    try {
                        const handle = await item.getAsFileSystemHandle();
                        if (handle && handle.kind === 'file') currentFileHandle = handle;
                    } catch (err) { /* keep null -> download on save */ }
                }
            }

            const reader = new FileReader();
            reader.onload = (ev) => loadContent(ev.target.result, file.name);
            reader.readAsText(file);
        });

        // --- Load & parse ---
        function loadContent(text, fileName) {
            currentFileName = fileName;
            fileBadge.textContent = fileName;
            codeEditor.value = text;

            const isYaml = fileName.endsWith('.yaml') || fileName.endsWith('.yml');
            let parsedOk = false;
            try {
                if (isYaml) {
                    configData = jsyaml.load(text);
                    isClash = true;
                    parsedOk = true;
                } else if (fileName.endsWith('.json')) {
                    configData = JSON.parse(text);
                    isClash = false;
                    parsedOk = true;
                }
            } catch (e) {
                parsedOk = false;
            }

            dropzonePanel.style.display = 'none';
            workspacePanel.style.display = 'flex';

            if (parsedOk) {
                renderVisualEditor();
                switchTab('tab-visual');
            } else {
                switchTab('tab-code');
            }
        }

        // --- Tabs ---
        function switchTab(target) {
            document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.target === target));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.toggle('active', c.id === target));
        }

        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', () => {
                const target = tab.dataset.target;
                if (target === 'tab-visual') {
                    try {
                        configData = isClash ? jsyaml.load(codeEditor.value) : JSON.parse(codeEditor.value);
                        renderVisualEditor();
                    } catch (e) {
                        alert("文件格式错误，无法生成可视化界面！请在源文件模式下修复。");
                        return;
                    }
                }
                switchTab(target);
            });
        });

        // --- Visual editor rendering ---
        function arrayToText(arr) {
            if (!arr) return "";
            if (Array.isArray(arr)) return arr.join('\n');
            return arr.toString();
        }

        function renderVisualEditor() {
            if (!configData) return;

            if (isClash) {
                document.getElementById('singbox-sections').style.display = 'none';
                document.getElementById('clash-sections').style.display = 'block';
                document.getElementById('yaml-warning').style.display = 'block';

                const groupsGrid = document.getElementById('clash-groups-grid');
                const nodesGrid = document.getElementById('clash-nodes-grid');
                const rulesCard = document.getElementById('clash-rules-card');
                groupsGrid.innerHTML = '';
                nodesGrid.innerHTML = '';

                // Clash Rules
                if (configData.rules) {
                    rulesCard.innerHTML = `
                        <div class="card" style="width:100%;">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
                                <h3>全局分流规则 <span class="tag-badge-rule">RULES</span></h3>
                                <button class="btn secondary" id="btn-add-rule" style="padding:0.3rem 0.8rem; font-size:0.8rem;">➕ 插入新规则</button>
                            </div>
                            <div class="input-group">
                                <label style="margin-bottom:1rem;">拖拽左侧 ☰ 即可排序，修改立即生效</label>
                                <div id="clash-rules-list" class="drag-list"></div>
                            </div>
                        </div>
                    `;

                    const rulesList = document.getElementById('clash-rules-list');
                    configData.rules.forEach((rule, idx) => {
                        const item = document.createElement('div');
                        item.className = 'drag-item';
                        item.innerHTML = `
                            <span class="drag-handle" title="拖拽排序">☰</span>
                            <input type="text" data-sec="rules-item" data-idx="${idx}" value="${rule}">
                            <button class="btn-del" data-action="del-rule" data-idx="${idx}" title="删除此规则">✖</button>
                        `;
                        rulesList.appendChild(item);
                    });

                    new Sortable(rulesList, {
                        handle: '.drag-handle',
                        animation: 150,
                        ghostClass: 'sortable-ghost',
                        onEnd: function (evt) {
                            const item = configData.rules.splice(evt.oldIndex, 1)[0];
                            configData.rules.splice(evt.newIndex, 0, item);
                            codeEditor.value = jsyaml.dump(configData, { lineWidth: -1 });
                            renderVisualEditor();
                        }
                    });

                    document.getElementById('btn-add-rule').onclick = () => {
                        configData.rules.unshift("DOMAIN-SUFFIX,example.com,DIRECT");
                        codeEditor.value = jsyaml.dump(configData, { lineWidth: -1 });
                        renderVisualEditor();
                    };
                } else {
                    rulesCard.innerHTML = '<p style="color:var(--text-muted);">当前配置无分流规则或解析失败</p>';
                }

                // Clash Proxy Groups
                if (configData['proxy-groups']) {
                    configData['proxy-groups'].forEach((group, i) => {
                        const card = document.createElement('div');
                        card.className = 'card';
                        card.innerHTML = `
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 1rem;">
                                <h3 style="margin-bottom:0;">${group.name}</h3>
                                <select data-sec="proxy-groups" data-idx="${i}" data-key="type" style="background:rgba(0,0,0,0.5); color:var(--text-main); border:1px solid var(--accent); padding:0.3rem 0.6rem; border-radius:6px; font-size:0.85rem; outline:none; cursor:pointer;">
                                    <option value="select" ${group.type === 'select' ? 'selected' : ''}>SELECT (手动)</option>
                                    <option value="url-test" ${group.type === 'url-test' ? 'selected' : ''}>URL-TEST (自动)</option>
                                    <option value="fallback" ${group.type === 'fallback' ? 'selected' : ''}>FALLBACK (主备)</option>
                                </select>
                            </div>
                            <div class="input-group">
                                <label>包含的节点/组 (每行一个)</label>
                                <textarea data-sec="proxy-groups" data-idx="${i}" data-key="proxies">${arrayToText(group.proxies)}</textarea>
                            </div>
                        `;
                        groupsGrid.appendChild(card);
                    });
                }

                // Clash Proxies
                if (configData.proxies) {
                    configData.proxies.forEach((proxy, i) => {
                        const card = document.createElement('div');
                        card.className = 'card';
                        card.innerHTML = `
                            <h3>${proxy.name} <span class="tag-badge">${(proxy.type || '').toUpperCase()}</span></h3>
                            <div class="input-group">
                                <label>服务器 (Server / IP)</label>
                                <input type="text" data-sec="proxies" data-idx="${i}" data-key="server" value="${proxy.server || ''}">
                            </div>
                            <div class="input-group">
                                <label>端口 (Port)</label>
                                <input type="number" data-sec="proxies" data-idx="${i}" data-key="port" value="${proxy.port || ''}">
                            </div>
                        `;
                        nodesGrid.appendChild(card);
                    });
                }

            } else {
                document.getElementById('singbox-sections').style.display = 'block';
                document.getElementById('clash-sections').style.display = 'none';
                document.getElementById('yaml-warning').style.display = 'none';

                const renderGrid = (id, items, renderFn) => {
                    const grid = document.getElementById(id);
                    grid.innerHTML = '';
                    if (items) items.forEach((item, idx) => grid.appendChild(renderFn(item, idx)));
                };

                renderGrid('inbounds-grid', configData.inbounds, (ob, i) => {
                    const card = document.createElement('div');
                    card.className = 'card';
                    card.innerHTML = `
                        <h3>${ob.tag || 'Unnamed'} <span class="tag-badge">${(ob.type||'').toUpperCase()}</span></h3>
                        <div class="input-group"><label>Listen (监听地址)</label><input type="text" data-sec="inbounds" data-idx="${i}" data-key="listen" value="${ob.listen || ''}"></div>
                        <div class="input-group"><label>Listen Port (监听端口)</label><input type="number" data-sec="inbounds" data-idx="${i}" data-key="listen_port" value="${ob.listen_port || ''}"></div>
                    `;
                    return card;
                });

                renderGrid('dns-servers-grid', configData.dns?.servers, (ds, i) => {
                    const card = document.createElement('div');
                    card.className = 'card';
                    card.innerHTML = `
                        <h3>${ds.tag || 'Unnamed'} <span class="tag-badge">${(ds.type||'').toUpperCase()}</span></h3>
                        <div class="input-group"><label>Server/Address (服务器地址)</label><input type="text" data-sec="dns.servers" data-idx="${i}" data-key="server" value="${ds.server || ds.address || ''}"></div>
                    `;
                    return card;
                });

                renderGrid('dns-rules-grid', configData.dns?.rules, (r, i) => {
                    const card = document.createElement('div');
                    card.className = 'card';
                    let matchersHtml = '';
                    for (let k in r) {
                        if (k === 'server') continue;
                        matchersHtml += `<div class="input-group"><label>${k} (匹配规则)</label><textarea data-sec="dns.rules" data-idx="${i}" data-key="${k}">${arrayToText(r[k])}</textarea></div>`;
                    }
                    card.innerHTML = `
                        <h3>Rule #${i+1} <span class="tag-badge-rule">DNS RULE</span></h3>
                        ${matchersHtml || '<p style="color:var(--text-muted);font-size:0.8rem;margin-bottom:1rem;">(全局默认规则)</p>'}
                        <div class="input-group"><label>目标 DNS (server)</label><input type="text" data-sec="dns.rules" data-idx="${i}" data-key="server" value="${r.server || ''}"></div>
                    `;
                    return card;
                });

                renderGrid('route-rules-grid', configData.route?.rules, (r, i) => {
                    const card = document.createElement('div');
                    card.className = 'card';
                    let matchersHtml = '';
                    for (let k in r) {
                        if (k === 'outbound') continue;
                        matchersHtml += `<div class="input-group"><label>${k} (匹配规则)</label><textarea data-sec="route.rules" data-idx="${i}" data-key="${k}">${arrayToText(r[k])}</textarea></div>`;
                    }
                    card.innerHTML = `
                        <h3>Rule #${i+1} <span class="tag-badge-rule">ROUTE RULE</span></h3>
                        ${matchersHtml || '<p style="color:var(--text-muted);font-size:0.8rem;margin-bottom:1rem;">(全局默认规则)</p>'}
                        <div class="input-group"><label>目标出站组/节点 (outbound)</label><input type="text" data-sec="route.rules" data-idx="${i}" data-key="outbound" value="${r.outbound || ''}"></div>
                    `;
                    return card;
                });

                const groupsGrid = document.getElementById('groups-grid');
                const nodesGrid = document.getElementById('nodes-grid');
                groupsGrid.innerHTML = '';
                nodesGrid.innerHTML = '';

                if (configData.outbounds) {
                    configData.outbounds.forEach((ob, i) => {
                        const card = document.createElement('div');
                        card.className = 'card';

                        if (['selector', 'urltest'].includes(ob.type)) {
                            card.innerHTML = `
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 1rem;">
                                    <h3 style="margin-bottom:0;">${ob.tag}</h3>
                                    <select data-sec="outbounds" data-idx="${i}" data-key="type" style="background:rgba(0,0,0,0.5); color:var(--text-main); border:1px solid var(--accent); padding:0.3rem 0.6rem; border-radius:6px; font-size:0.85rem; outline:none; cursor:pointer;">
                                        <option value="selector" ${ob.type === 'selector' ? 'selected' : ''}>SELECTOR (手动选择)</option>
                                        <option value="urltest" ${ob.type === 'urltest' ? 'selected' : ''}>URLTEST (自动测速)</option>
                                    </select>
                                </div>
                                <div class="input-group"><label>包含的节点/组 (每行一个)</label><textarea data-sec="outbounds" data-idx="${i}" data-key="outbounds">${arrayToText(ob.outbounds)}</textarea></div>
                            `;
                            groupsGrid.appendChild(card);
                        } else if (['vless', 'trojan', 'shadowsocks', 'vmess', 'hysteria2', 'tuic'].includes(ob.type)) {
                            let proxyIp = "";
                            if (ob.transport && ob.transport.path && ob.transport.path.includes('proxyip=')) {
                                proxyIp = ob.transport.path.split('proxyip=')[1].split('&')[0];
                            }
                            card.innerHTML = `
                                <h3>${ob.tag} <span class="tag-badge">${ob.type.toUpperCase()}</span></h3>
                                <div class="input-group"><label>服务器 (Server)</label><input type="text" data-sec="outbounds" data-idx="${i}" data-key="server" value="${ob.server || ''}"></div>
                                <div class="input-group"><label>端口 (Port)</label><input type="number" data-sec="outbounds" data-idx="${i}" data-key="server_port" value="${ob.server_port || ''}"></div>
                                ${ob.transport && ob.transport.type === 'ws' ? `<div class="input-group"><label>Proxy IP (用于跳板)</label><input type="text" data-sec="outbounds" data-idx="${i}" data-key="proxyip" value="${proxyIp}"></div>` : ''}
                            `;
                            nodesGrid.appendChild(card);
                        }
                    });
                }
            }

            // Delete rule buttons
            document.querySelectorAll('.btn-del').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const idx = e.target.dataset.idx;
                    configData.rules.splice(idx, 1);
                    codeEditor.value = jsyaml.dump(configData, { lineWidth: -1 });
                    renderVisualEditor();
                });
            });

            // Universal change listener
            document.querySelectorAll('#tab-visual input, #tab-visual textarea, #tab-visual select').forEach(el => {
                el.addEventListener('change', (e) => {
                    const sec = e.target.dataset.sec;
                    const idx = e.target.dataset.idx;
                    const key = e.target.dataset.key;
                    let val = e.target.value;

                    if (e.target.type === 'number') val = parseInt(val);
                    else if (e.target.tagName === 'TEXTAREA') {
                        val = val.split('\n').map(s => s.trim()).filter(s => s !== "");
                        if (val.length === 0) val = undefined;
                    }

                    let targetObj;
                    if (isClash) {
                        if (sec === 'rules-item') {
                            configData.rules[idx] = val;
                            codeEditor.value = jsyaml.dump(configData, { lineWidth: -1 });
                            return;
                        }
                        if (sec === 'proxy-groups') targetObj = configData['proxy-groups'][idx];
                        else if (sec === 'proxies') targetObj = configData.proxies[idx];
                    } else {
                        if (sec === 'inbounds') targetObj = configData.inbounds[idx];
                        else if (sec === 'dns.servers') targetObj = configData.dns.servers[idx];
                        else if (sec === 'dns.rules') targetObj = configData.dns.rules[idx];
                        else if (sec === 'route.rules') targetObj = configData.route.rules[idx];
                        else if (sec === 'outbounds') targetObj = configData.outbounds[idx];
                    }

                    if (targetObj) {
                        if (key === 'proxyip' && targetObj.transport) {
                            let path = targetObj.transport.path;
                            if (path.includes('proxyip=')) targetObj.transport.path = path.replace(/proxyip=[^&]+/, 'proxyip=' + val);
                            else targetObj.transport.path = path + (path.includes('?') ? '&' : '?') + 'proxyip=' + val;
                        }
                        else if (key === 'server' && targetObj.address !== undefined) {
                            targetObj.address = val;
                        }
                        else if (key === 'type' && !isClash) {
                            targetObj.type = val;
                            if (val === 'selector') {
                                delete targetObj.url; delete targetObj.interval; delete targetObj.tolerance;
                            } else if (val === 'urltest') {
                                delete targetObj.default;
                                if (!targetObj.url) targetObj.url = "https://www.gstatic.com/generate_204";
                                if (!targetObj.interval) targetObj.interval = "3m";
                            }
                        }
                        else if (key === 'type' && isClash) {
                            targetObj.type = val;
                            if (val === 'select') {
                                delete targetObj.url; delete targetObj.interval; delete targetObj.tolerance;
                            } else if (val === 'url-test' || val === 'fallback') {
                                if (!targetObj.url) targetObj.url = "http://www.gstatic.com/generate_204";
                                if (!targetObj.interval) targetObj.interval = 300;
                            }
                        }
                        else {
                            if (val === undefined) delete targetObj[key];
                            else targetObj[key] = val;
                        }
                    }

                    codeEditor.value = isClash ? jsyaml.dump(configData, { lineWidth: -1 }) : JSON.stringify(configData, null, 2);
                });
            });
        }

        // --- Save ---
        function triggerDownload(content, filename) {
            const blob = new Blob([content], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        async function flashButton(btn, msg) {
            const original = btn.textContent;
            btn.textContent = msg;
            setTimeout(() => btn.textContent = original, 2000);
        }

        btnSave.addEventListener('click', async () => {
            const content = codeEditor.value;

            // Preferred: write back to the opened file handle
            if (isFSApiSupported && currentFileHandle) {
                try {
                    const writable = await currentFileHandle.createWritable();
                    await writable.write(content);
                    await writable.close();
                    flashButton(btnSave, "✅ 已保存");
                    return;
                } catch (err) { /* fall through to Save As / download */ }
            }

            // Fallback: Save As picker where supported
            if (isFSApiSupported) {
                try {
                    const newHandle = await window.showSaveFilePicker({ suggestedName: currentFileName, types: FILE_TYPES });
                    const writable = await newHandle.createWritable();
                    await writable.write(content);
                    await writable.close();
                    currentFileHandle = newHandle;
                    currentFileName = newHandle.name;
                    fileBadge.textContent = currentFileName;
                    flashButton(btnSave, "✅ 已保存");
                    return;
                } catch (err) { return; /* user cancelled */ }
            }

            // Last resort: browser download
            triggerDownload(content, currentFileName);
            flashButton(btnSave, "✅ 已下载");
        });
    </script>
</body>
</html>
