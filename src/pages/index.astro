---
import packageJson from '../../package.json';
const version = packageJson.version;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Web Tools Hub</title>
    <meta name="description" content="A collection of fast, static web tools for everyday use.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="background-elements">
        <div class="glow-orb orb-1"></div>
        <div class="glow-orb orb-2"></div>
    </div>
    
    <div class="container">
        <header>
            <h1>Tool<span class="highlight">Hub</span></h1>
            <p>Your premium collection of daily web utilities.</p>
        </header>

        <main class="tools-grid">
            <a href="/base64" class="tool-card">
                <div class="tool-icon">🛠️</div>
                <div class="tool-info">
                    <h2>Base64 Encoder/Decoder</h2>
                    <p>Quickly encode or decode base64 strings entirely in your browser.</p>
                </div>
            </a>
            
            <a href="/sing-box" class="tool-card">
                <div class="tool-icon">📦</div>
                <div class="tool-info">
                    <h2>Sing-Box Editor</h2>
                    <p>Visual config editor for Sing-Box. Manage your nodes and rules.</p>
                </div>
            </a>
            
            <a href="uuid" class="tool-card">
                <div class="tool-icon">🔑</div>
                <div class="tool-info">
                    <h2>UUID Generator</h2>
                    <p>Generate secure v4 UUIDs instantly in your browser.</p>
                </div>
            </a>
            
            <a href="https://wp.freetis.com/admin" class="tool-card" target="_blank" rel="noopener noreferrer">
                <div class="tool-icon">⚙️</div>
                <div class="tool-info">
                    <h2>Admin Panel</h2>
                    <p>Access the WordPress admin dashboard at wp.freetis.com</p>
                </div>
            </a>
        </main>
        
        <footer>
            <p>&copy; 2026 Web Tools Hub. All operations run locally. | v{version}</p>
        </footer>
    </div>
</body>
</html>
